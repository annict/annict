{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["go/**"],
      "options": {
        "sortTailwindcss": {}
      }
    }
  ],
  "ignorePatterns": [
    "**/node_modules/",
    "**/vendor/",
    "apm.lock.yaml",
    "apm_modules/",
    "go/internal/query/*.go",
    "go/internal/templates/*_templ.go",
    "go/static/",
    "rails/app/assets/builds/",
    "rails/app/docs/",
    "rails/app/views/",
    "rails/db/",
    "rails/public/",
    "rails/sorbet/",
    "rails/tmp/"
  ]
}
