  #
  #
  #   [1]: https://docs.aws.amazon.com/AmazonS3/latest/dev/bucket-key.html
  #   [2]: https://docs.aws.amazon.com/AmazonS3/latest/API/API_CopyObject.html
  #
  # @option params [String] :copy_source_sse_customer_algorithm
