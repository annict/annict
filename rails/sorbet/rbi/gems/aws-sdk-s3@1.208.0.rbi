  #         {
  #           etag: "ETag",
  #           checksum_crc32: "ChecksumCRC32",
  #           checksum_crc32c: "ChecksumCRC32C",
  #           checksum_crc64nvme: "ChecksumCRC64NVME",
  #           checksum_sha1: "ChecksumSHA1",
  #           checksum_sha256: "ChecksumSHA256",
  #           part_number: 1,
  #         },
  #       ],
  #     },
  #     upload_id: "MultipartUploadId", # required
