  #     # polls in a loop until condition is true
  #     resource.wait_until(options) {|resource| condition}
  #
  # ## Example
  #
  #     instance.wait_until(max_attempts:10, delay:5) do |instance|
  #       instance.state.name == 'running'
  #     end
  #
