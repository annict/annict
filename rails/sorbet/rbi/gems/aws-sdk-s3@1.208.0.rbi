  # pkg:gem/aws-sdk-s3#lib/aws-sdk-s3/legacy_signer.rb:92
  def signing_string_date(request); end

  # From the S3 developer guide:
  #
  #     StringToSign =
  #       HTTP-Verb ` "\n" `
  #       content-md5 ` "\n" `
  #       content-type ` "\n" `
