  #   [3]: https://docs.aws.amazon.com/AmazonS3/latest/API/API_RestoreObject.html
  #   [4]: https://docs.aws.amazon.com/AmazonS3/latest/dev/CopyingObjectsExamples.html
  #
  # @option params [String] :website_redirect_location
