  #   presigned URL will use the bucket name as a virtual host.
  #
  #     bucket = Aws::S3::Bucket.new('my.bucket.com')
  #     bucket.object('key').presigned_request(virtual_host: true)
  #     #=> ["http://my.bucket.com/key?...", {}]
