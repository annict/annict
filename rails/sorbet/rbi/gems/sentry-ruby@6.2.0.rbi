# pkg:gem/sentry-ruby#lib/sentry/net/http.rb:9
module Sentry::Net; end

# pkg:gem/sentry-ruby#lib/sentry/net/http.rb:10
module Sentry::Net::HTTP
  include ::Sentry::Utils::HttpTracing

  # To explain how the entire thing works, we need to know how the original Net::HTTP#request works
  # Here's part of its definition. As you can see, it usually calls itself inside a #start block
  #
  # ```
  # def request(req, body = nil, &block)
  #   unless started?
  #     start {
  #       req['connection'] ||= 'close'
  #       return request(req, body, &block) # <- request will be called for the second time from the first call
  #     }
  #   end # .....
  # end
  # ```
  #
  # So we're only instrumenting request when `Net::HTTP` is already started
  #
  # pkg:gem/sentry-ruby#lib/sentry/net/http.rb:33
  def request(req, body = T.unsafe(nil), &block); end

  private

  # pkg:gem/sentry-ruby#lib/sentry/net/http.rb:66
  def extract_request_info(req); end

  # pkg:gem/sentry-ruby#lib/sentry/net/http.rb:61
  def from_sentry_sdk?; end
end

