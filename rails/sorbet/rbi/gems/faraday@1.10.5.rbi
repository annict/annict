  def lock!; end

  # pkg:gem/faraday#lib/faraday/rack_builder.rb:89
  def locked?; end

  # pkg:gem/faraday#lib/faraday/rack_builder.rb:103
  def request(key, *args, **_arg2, &block); end

  # pkg:gem/faraday#lib/faraday/rack_builder.rb:107
