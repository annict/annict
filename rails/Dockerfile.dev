FROM ruby:3.3.10-slim-bookworm

ARG USER_ID=1000
ARG GROUP_ID=1000
ARG USERNAME=developer

RUN <<EOF
apt update
apt dist-upgrade -yq

PACKAGES=$(cat <<'PKGLIST' | sed 's/#.*//'
  build-essential
  curl
  file               # Shrineによる画像アップロードに必要
  fzf                # Claude Codeで使用
  git
  gnupg              # PostgreSQLやNode.jsのインストールに必要
  imagemagick        # Shrineによる画像アップロードに必要
  jq                 # Claude Codeで使用
  libasound2         # Playwright: ALSA音声ライブラリ
  libatk-bridge2.0-0 # Playwright: ATKブリッジ（アクセシビリティ）
  libatk1.0-0        # Playwright: ATK（アクセシビリティツールキット）
  libcairo2          # Playwright: 2Dグラフィックスライブラリ
  libcups2           # Playwright: 印刷システムライブラリ
  libdrm2            # Playwright: Direct Rendering Manager
  libgbm1            # Playwright: Generic Buffer Management（GPU）
  libnspr4           # Playwright: Netscape Portable Runtime
  libnss3            # Playwright: Network Security Services
  libpango-1.0-0     # Playwright: テキストレンダリング
  libxcomposite1     # Playwright: X11 Composite拡張
  libxdamage1        # Playwright: X11 Damage拡張
  libxfixes3         # Playwright: X11 Fixes拡張
  libxkbcommon0      # Playwright: XKBキーボード処理
  libxrandr2         # Playwright: X11 RandR拡張（ディスプレイ設定）
  libyaml-dev        # psych gemのインストールに必要
  lsb-release
  nano               # Claude Codeで使用
  ripgrep            # Claude Codeで使用
  sudo
  tree               # Claude Codeで使用
  vim                # Claude Codeで使用
  zsh
PKGLIST
)

apt install -y --no-install-recommends $PACKAGES
rm -rf /var/lib/apt/lists/*
EOF

# PostgreSQLのセットアップ
RUN \
  curl -sS https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - && \
  echo "deb https://apt.postgresql.org/pub/repos/apt/ $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list && \
  apt update && \
  apt install -y --no-install-recommends \
  libpq-dev \
  postgresql-client-17

# Node.jsのセットアップ
RUN \
  # https://github.com/nodesource/distributions/wiki/How-to-select-the-Node.js-version-to-install
  curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
  apt install -y --no-install-recommends \
  nodejs=22.17.0-1nodesource1

RUN \
  groupadd -g ${GROUP_ID} ${USERNAME} && \
  useradd -u ${USER_ID} -g ${GROUP_ID} -m -s /bin/bash ${USERNAME} && \
  echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /workspace

USER ${USERNAME}

# npmのグローバルインストール先を一般ユーザーのホームディレクトリに設定
ENV NPM_CONFIG_PREFIX=/home/${USERNAME}/.npm-global
ENV PATH=$NPM_CONFIG_PREFIX/bin:$PATH

COPY --from=1password/op:2 /usr/local/bin/op /usr/local/bin/op

RUN npm install --global yarn@1.22.22
RUN npm install -g @anthropic-ai/claude-code@latest
RUN npm install -g @modelcontextprotocol/server-filesystem

RUN gem install bundler -v 2.3.12

# zshをデフォルトシェルに設定
SHELL ["/bin/zsh", "-c"]
ENV SHELL=/bin/zsh

RUN touch /home/${USERNAME}/.zshrc

RUN git config --global user.email "me@shimba.co" && \
    git config --global user.name "Koji Shimba"

CMD ["/bin/zsh"]
