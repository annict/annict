<% title = t "head.title.providers.index" %>
<% set_meta_tags title: title, reverse: true, prefix: false %>

<%= render "settings/nav" %>

<div class="u-container-narrow mt-3">
  <h2 class="fw-bold h3 mb-0">
    <%= t "noun.icalendar" %>
  </h2>
</div>

<div class="mt-3 u-container-narrow u-container-flat">
  <div class="card u-card-flat">
    <div class="card-body">
      <p>
        <%= t "messages.ics.you_can_see" %>
      </p>

      <div class="mt-3">
        <%= text_field_tag(
          "",
          ics_calendar_url(current_user.username),
          onclick: "this.select();",
          class: "form-control",
          autocomplete: "off"
        ) %>
      </div>

      <p class="mt-3">
        <%= t "messages.ics.you_can_use" %>
      </p>

      <div class="mt-3">
        <%= text_field_tag(
          "",
          ics_calendar_alt_url(current_user.username),
          onclick: "this.select();",
          class: "form-control",
          autocomplete: "off"
        ) %>
      </div>
    </div>
  </div>
</div>
